%% monograph-template.sty — project style file for monograph-template.tex (memoir)
%%
%% This is the SOLE package loaded by monograph-template.tex. It (1) loads the
%% shared preamble packages vendored in _packages/ (pristine copies pinned in
%% _packages/vendor.lock — DO NOT edit them there), then (2) defines everything
%% specific to this monograph in the "Project-specific additions" section
%% (including the memoir page layout — only \documentclass and semantic
%% metadata belong in the .tex).
%%
%% When you start a real book from this template, rename this file to match
%% your master and \usepackage{...} it there.
%%
%%   Shared, vendored:  di-base-monograph (memoir, chapter-scoped numbering +
%%                       axiom), which pulls in di-base-core (fonts, packages,
%%                       hyperref/cleveref, theorem family).
%%   Project-specific:  memoir layout, graphics, project macros — EDIT here.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{monograph-template}[2026/07/15 monograph-template project preamble]

% ═══════════════════════════════════════════════════════════════════════════
