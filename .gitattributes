.gitattributes merge=union

# Ensure consistent line endings
*.tex  text eol=lf
*.bib  text eol=lf
*.cls  text eol=lf
*.sty  text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.py   text eol=lf
*.sh   text eol=lf

# Binary files
*.pdf  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.eps  binary
