# .chktexrc — chktex configuration
#
# Suppress warning numbers that are too noisy for collaborative LaTeX writing.
# See: https://www.nongnu.org/chktex/ChkTeX.pdf

# 1  — Command terminated with space (too many false positives with macros)
# 3  — Enclose 's previous/next character in group (false positive on d')
# 6  — Italic correction: unreliable at group/`\par` boundaries (flags
#      missing \/ before \par, then flags it as unneeded once added)
# 8  — Wrong length of dash (stylistic, not an error)
# 9  — Bracket matching: false positive on half-open intervals like
#      "[0, \infty)" (paired with 17 below; both are unreliable once a
#      document uses interval notation)
# 13 — Intersentence spacing (handled by texwrap.py)
# 17 — Bracket-count mismatch: same false positive as 9, cascades to the
#      end-of-file tally after one interval-notation line
# 18 — Straight quotes: false positive on tikz-cd's `"label"` edge-arrow
#      syntax (VerbEnvir does not suppress this check inside tikzcd/verbatim)
# 24 — Delete this space to maintain correct pagereferences
# 36 — Vertical rules in tables (stylistic preference)
# 44 — User Regex (disabled by default)
CmdLine {
  -n1 -n3 -n6 -n8 -n9 -n13 -n17 -n18 -n24 -n36 -n44
}

# Treat these environments as verbatim (no linting inside them)
VerbEnvir {
  verbatim,Verbatim,lstlisting,minted,filecontents,comment,
  tikzpicture,tikzcd
}

# Treat these environments as math (no "missing $" warnings)
MathEnvir {
  equation,equation*,align,align*,gather,gather*,multline,multline*,
  split,aligned,alignedat,gathered,cases,subequations
}
