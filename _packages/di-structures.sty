% Bar-of-fraktur combinations (tuples/sequences of fraktur elements)
\newcommand{\bfs}{\bar{\fs}}
\newcommand{\bft}{\bar{\ft}}
\newcommand{\bfx}{\bar{\fx}}
\newcommand{\bfy}{\bar{\fy}}

% ── Typewriter letters ───────────────────────────────────────────────────────
% \tZ is the typewriter Z used as the symbol for the value lattice/space.

\newcommand{\tZ}{\mathtt{Z}}    % value-space symbol; critical dependency below
\newcommand{\tM}{\mathtt{M}}    % typewriter M (model/sort)
\newcommand{\tL}{\mathtt{L}}    % typewriter L (language)

% Bar-of-typewriter (tuples of typewriter-font variables)
\newcommand{\btx}{\bar{\mathtt{x}}}
\newcommand{\bty}{\bar{\mathtt{y}}}
\newcommand{\btz}{\bar{\mathtt{z}}}

% ── Bar letters (common "bar" shorthands safe across all papers) ─────────────
% Note: \bx, \by, \bz, \bv, \bw, \ba, \bb, \bs are NOT defined here
% because some papers use \bar{x} while others use \mathbf{x}.  Define locally.

\newcommand{\bk}{\bar{k}}
\newcommand{\bl}{\bar{\ell}}
\newcommand{\bp}{\bar{p}}
\newcommand{\bq}{\bar{q}}
\newcommand{\br}{\bar{r}}

