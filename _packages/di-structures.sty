% Semigroup/Ramsey ultralimit (lowercase; used in Ramsey context)
\DeclareMathOperator*{\ulim}{u\!\operatorname{-lim}}
\DeclareMathOperator*{\Ilim}{I\!\operatorname{-lim}}

% ── Norm and pairing delimiters ───────────────────────────────────────────────

\newcommand{\nrm}[1]{\ensuremath{\left\lvert #1 \right\rvert}}
\newcommand{\Nrm}[1]{\ensuremath{\left\lVert #1 \right\rVert}}
\newcommand{\NRM}[1]{{\left\vert\kern-0.25ex\left\vert\kern-0.25ex
  \left\vert #1 \right\vert\kern-0.25ex\right\vert\kern-0.25ex\right\vert}}
\newcommand{\Ninf}[1]{\Nrm{#1}_{\infty}}
\newcommand{\None}[1]{\Nrm{#1}_{1}}
\newcommand{\Naught}[1]{\Nrm{#1}_{0}}
\newcommand{\PPabs}{\PP_{\!\nrm{\cdot}}}

\newcommand{\pair}[2]{\ensuremath{\left\langle #1 \mid #2 \right\rangle}}
\newcommand{\Pair}[2]{\ensuremath{\left\lAngle #1 \mid #2 \right\rAngle}}

% Delimiter families built from stix bracket primitives
\newcommand{\Angle}[1]{\ensuremath{\left\lAngle #1 \right\rAngle}}
\newcommand{\Brack}[1]{\ensuremath{\left\lBrack #1 \right\rBrack}}
\newcommand{\Brace}[1]{\ensuremath{\left\lBrace #1 \right\rBrace}}
\newcommand{\Paren}[1]{\ensuremath{\left( #1 \right)}}
\newcommand{\lrAngle}[1]{\ensuremath{%
  \left\lAngle\!\left\lAngle #1 \right\rAngle\!\right\rAngle}}

% ── Forcing and model-theoretic relations ────────────────────────────────────

\newcommand{\forces}{\Vdash}
\newcommand{\nforces}{\nVdash}
\newcommand{\isforcedby}{\dashV}
\newcommand{\ismodeledby}{\Dashv}
\newcommand{\nmodels}{\nvDash}
\def\appmod{\mathrel|\joinrel\approx}
\def\wforces{\mathrel\|\joinrel\sim}
\newcommand{\nwforces}{\not\!\wforces}
\newcommand{\nappmod}{\not\!\appmod}

