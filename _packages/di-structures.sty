%% di-structures.sty — Dueñez–Iovino notation for real-valued logic
%%
%% Defines the shared mathematical notation for the real-valued structure
%% framework (continuous logic / Chang–Keisler / Ben Yaacov–Berenstein–
%% Henson–Usvyatsov tradition).
%%
%% Requires di-base to be loaded first.
%%
%% Conflict resolutions documented here:
%%   \dd       — \DeclareMathOperator* (starred; non-starred locally if needed)
%%   \cE, \UU  — \newcommand (letter, not operator; no operator spacing)
%%   \Ulim etc.— \DeclareMathOperator* (starred)
%%   \Ftp      — hyphenated form \cF\text{-}\!\tp (subscript form locally if needed)
%%   \claim    — NOT defined here; conflict between papers; define locally
%%   \bx,\by,\bz,\bv,\bw,\ba,\bb,\bs
%%               — NOT defined here; papers use either \bar{x} or \mathbf{x};
%%                 define locally
%%   \VStr,\VZStr,\ZStr — reference \VZ and \tZ which are defined below

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{di-structures}[2026/05/31 Duenez-Iovino real-valued logic notation]

