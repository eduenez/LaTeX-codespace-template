# -*- mode: gitignore; -*-

# ── Editor backup files ──────────────────────────────────────────────────────
*~
\#*\#
.\#*
*.swp
*.swo

# ── Build output directory ───────────────────────────────────────────────────
build/

# ── Core LaTeX auxiliary files ───────────────────────────────────────────────
*.aux
*.lof
*.log
*.lot
*.fls
*.out
*.toc
*.fmt
*.fot
*.cb
*.cb2
.*.lb
*.rip

# ── Intermediate documents ───────────────────────────────────────────────────
*.dvi
*.xdv
*-converted-to.*
*.ps
*.eps
*.pdf

# ── Bibliography auxiliary files ─────────────────────────────────────────────
*.bbl
*.bcf
*.blg
*-blx.aux
*-blx.bib
*.run.xml

# ── Build tool auxiliary files ───────────────────────────────────────────────
*.fdb_latexmk
*.synctex
*.synctex(busy)
*.synctex.gz
*.synctex.gz(busy)
*.pdfsync

# ── Algorithms ───────────────────────────────────────────────────────────────
*.alg
*.loa

# ── amsthm ───────────────────────────────────────────────────────────────────
*.thm

# ── beamer ───────────────────────────────────────────────────────────────────
*.nav
*.pre
*.snm
*.vrb

# ── glossaries ───────────────────────────────────────────────────────────────
*.acn
*.acr
*.glg
*.glo
*.gls
*.glsdefs

# ── hyperref ─────────────────────────────────────────────────────────────────
*.brf

# ── makeidx ──────────────────────────────────────────────────────────────────
*.idx
*.ilg
*.ind

# ── minitoc ──────────────────────────────────────────────────────────────────
*.maf
*.mlf
*.mlt
*.mtc[0-9]*
*.slf[0-9]*
*.slt[0-9]*
*.stc[0-9]*

# ── minted ───────────────────────────────────────────────────────────────────
_minted*
*.pyg

# ── nomencl ──────────────────────────────────────────────────────────────────
*.nlg
*.nlo
*.nls

# ── todonotes ────────────────────────────────────────────────────────────────
*.tdo

# ── listings ─────────────────────────────────────────────────────────────────
*.lol

# ── xsim ─────────────────────────────────────────────────────────────────────
*.xsim

# ── latexindent backups ──────────────────────────────────────────────────────
*.bak[0-9]
*.bak[0-9][0-9]
indent.log

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE files ────────────────────────────────────────────────────────────────
.idea/
*.code-workspace
auto/
