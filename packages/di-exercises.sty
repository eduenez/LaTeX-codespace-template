%% di-exercises.sty — Exercise environments via xsim
%%
%% Provides: {exercise}, {solution}, \ExePart
%% Requires di-base to be loaded first (for hyperref and cleveref).
%%
%% Default: solutions are hidden.
%% To show solutions in a document: \xsimsetup{solution/print=true}
%%
%% Usage:
%%   \usepackage{di-base}
%%   \usepackage{di-exercises}

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{di-exercises}[2026/06/07 Exercise environments via xsim]

\RequirePackage{xsim}

\xsimsetup{
  exercise/within  = section,   % number as <section>.<counter>
  solution/print   = false,     % hide solutions by default
}

% Auto-label exercises that carry a user-supplied [ID=...].
% xsim stores the user ID in the "ID" property; \ExerciseID holds the
% auto-generated sequential counter.  When they differ the ID is
% user-supplied, so we emit \label{ID} to make \ref{ID} resolve.
\ExplSyntaxOn

\cs_new_protected:Npn \xsim_di_auto_label:
  {
    \tl_set:Nx \l_tmpa_tl { \GetExerciseProperty{ID} }
    \tl_if_eq:NNTF \l_tmpa_tl \ExerciseID
      {}   % equal → auto-generated numeric ID → skip
      { \exp_args:NV \label \l_tmpa_tl }   % user-supplied → label
  }

\xsim_addto_hook:nnnn {exercise} {exercise} {begin}
  { \xsim_di_auto_label: }

\ExplSyntaxOff

% Sub-part separator within an exercise.
% Optional argument is accepted for compatibility but not printed.
\NewDocumentCommand{\ExePart}{ O{} }{\par\noindent}
